<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.SplashScreen">
        <item name="android:windowSplashScreenBackground">#04070B</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_splash_empty</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="android:postSplashScreenTheme">@style/NormalTheme</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>

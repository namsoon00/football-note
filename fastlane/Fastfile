default_platform(:ios)

platform :ios do
  desc "Upload an IPA to TestFlight"
  lane :testflight do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: true
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: ENV.fetch("IOS_IPA_PATH"),
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end

  desc "Upload an IPA to App Store Connect for review"
  lane :appstore do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: true
    )

    upload_to_app_store(
      api_key: api_key,
      ipa: ENV.fetch("IOS_IPA_PATH"),
      submit_for_review: false,
      automatic_release: false,
      skip_metadata: true,
      skip_screenshots: true
    )
  end
end

platform :android do
  desc "Upload AAB to Google Play internal track"
  lane :internal do
    upload_to_play_store(
      track: "internal",
      aab: ENV.fetch("ANDROID_AAB_PATH"),
      json_key_data: ENV.fetch("PLAY_JSON_KEY"),
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_metadata: true
    )
  end

  desc "Upload AAB to Google Play production track"
  lane :production do
    upload_to_play_store(
      track: "production",
      aab: ENV.fetch("ANDROID_AAB_PATH"),
      json_key_data: ENV.fetch("PLAY_JSON_KEY"),
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_metadata: true
    )
  end
end

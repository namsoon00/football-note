  "educationScreenTitle": "Taeo's World Cup History Book",
  "educationHeroEyebrow": "YOUTH SESSION KIT",
  "educationHeroTitle": "Youth football content you can coach right away",
  "educationHeroBody": "Keep the explanations short, the repetitions high, and finish with one question. These three sessions are built for that flow.",
  "educationHeroStatLessons": "3 ready lessons",
  "educationHeroStatMinutes": "45-minute flow",
  "educationHeroStatPrinciples": "Coach cues included",
  "educationHeroStatHistory": "Quiz history included",
  "educationSectionLessonsTitle": "Ready Lessons",
  "educationSectionHistoryTitle": "Quiz History Study",
  "educationSectionHistoryBody": "These cards group together the years, competition names, and iconic moments that appear often in the quiz. Review one card, then jump straight into a round while the timeline is still fresh.",
  "educationSectionPrinciplesTitle": "Coaching Principles",
  "educationHistoryWorldCupEyebrow": "WORLD CUP ROOTS",
  "educationHistoryWorldCupTitle": "World Cup Foundations",
  "educationHistoryWorldCupSummary": "Use one card to lock in the first tournament, trophy change, and headline records that frame many World Cup history questions.",
  "educationHistoryWorldCupFocus": "Year + host",
  "educationHistoryWorldCupFact1": "The first FIFA World Cup was held in Uruguay in 1930.",
  "educationHistoryWorldCupFact2": "The Jules Rimet Trophy was used through 1970, and the current FIFA World Cup Trophy has been used since 1974.",
  "educationHistoryWorldCupFact3": "Brazil is the most common answer for the most men’s World Cup titles, and Miroslav Klose is the landmark all-time scorer.",
  "educationHistoryCompetitionEyebrow": "COMPETITION TIMELINE",
  "educationHistoryCompetitionTitle": "Competition Names And Launches",
  "educationHistoryCompetitionSummary": "League and European competition questions get easier when you pair launch years with inaugural champions or rebrand seasons.",
  "educationHistoryCompetitionFocus": "Launch + first champion",
  "educationHistoryCompetitionFact1": "The Premier League launched in 1992, and Manchester United won the inaugural 1992-93 title.",
  "educationHistoryCompetitionFact2": "The European Cup began operating as the UEFA Champions League from the 1992-93 season.",
  "educationHistoryCompetitionFact3": "Arsenal’s 2003-04 Invincibles season is one of the most common Premier League history anchors.",
  "educationHistoryMomentsEyebrow": "ICONIC MOMENTS",
  "educationHistoryMomentsTitle": "Iconic Moments And Women’s Football",
  "educationHistoryMomentsSummary": "Pair famous scenes with both the year and the opponent, and keep women’s football on its own timeline for faster recall.",
  "educationHistoryMomentsFocus": "Moment + opponent",
  "educationHistoryMomentsFact1": "Maradona’s “Hand of God” happened against England at the 1986 World Cup.",
  "educationHistoryMomentsFact2": "Zidane’s headbutt is an iconic scene from the 2006 FIFA World Cup final.",
  "educationHistoryMomentsFact3": "The first FIFA Women’s World Cup was held in China in 1991.",
  "educationModuleBallEyebrow": "BALL MASTERY",
  "educationModuleBallTitle": "Increase Touch Count",
  "educationModuleBallSummary": "A session that keeps both-foot inside and outside touches plus turns connected so younger players get comfortable with the ball.",
  "educationModuleBallAge": "U8-U10",
  "educationModuleBallDuration": "12 min",
  "educationModuleBallCue1": "Let the eyes come up sometimes while the feet stay light and active.",
  "educationModuleBallCue2": "Before asking for speed, check that the ball stays close to the body.",
  "educationModuleBallCue3": "After mistakes, encourage the next touch instead of stopping the drill.",
  "educationModulePassEyebrow": "FIRST TOUCH & PASS",
  "educationModulePassTitle": "First Touch Into Pass",
  "educationModulePassSummary": "Receive, turn, and release. This session links touch direction with passing accuracy in one flow.",
  "educationModulePassAge": "U10-U12",
  "educationModulePassDuration": "15 min",
  "educationModulePassCue1": "Ask players to scan over the shoulder once before receiving.",
  "educationModulePassCue2": "Coach the first touch into the space where the next pass should go.",
  "educationModulePassCue3": "Set the body shape and contact surface before asking for stronger pace.",
  "educationModuleDecisionEyebrow": "1V1 DECISION",
  "educationModuleDecisionTitle": "1v1 Breakthrough And Choice",
  "educationModuleDecisionSummary": "A decision session built around changing speed, freezing the defender, then finishing with either a shot or a pass.",
  "educationModuleDecisionAge": "U11-U13",
  "educationModuleDecisionDuration": "18 min",
  "educationModuleDecisionCue1": "Make the first step big, then keep the direction change short and sharp.",
  "educationModuleDecisionCue2": "Praise the timing and preparation first, not only the final result.",
  "educationModuleDecisionCue3": "After a success, revisit why it worked in one short sentence.",
  "educationPrincipleOneTitle": "One cue at a time",
  "educationPrincipleOneBody": "Keep instructions short and actionable. Single-word cues such as \"open\", \"scan\", and \"connect\" work well.",
  "educationPrincipleTwoTitle": "Find praise right after mistakes",
  "educationPrincipleTwoBody": "If you praise the preparation instead of only the outcome, players keep trying instead of freezing.",
  "educationPrincipleThreeTitle": "Use the last two minutes for questions",
  "educationPrincipleThreeBody": "Ask what felt easy today and what they want to change next time. That reflection helps the lesson stick.",
